<ResourceDictionary
    x:Class="NINA.Plugin.SeeDrift.Resources"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.Plugin.SeeDrift">

    <GeometryGroup x:Key="SeeDrift_Icon" FillRule="Nonzero">
        <PathGeometry Figures="M6,18 L6,8 L18,8"/>
        <PathGeometry Figures="M8,15 L11,12 L14,13 L17,9"/>
    </GeometryGroup>

    <DataTemplate x:Key="SeeDrift_Options" DataType="{x:Type local:SeeDriftPlugin}">
        <StackPanel Margin="8" MaxWidth="620">

            <TextBlock TextWrapping="Wrap" Foreground="#cbd5e1" FontSize="12" Margin="0,0,0,14"
                       Text="Sequence tip: add SeeDrift Start at the top of your night's sequence and SeeDrift Stop at the bottom. When Stop runs, SeeDrift reads logs, plate-solves saved LIGHT frames from that window, and appends the drift HTML report. Many exposures mean many solves: increase Concurrency if your PC can handle more parallel solving, or reduce it if CPU/RAM pressure is too high."/>

            <Grid Margin="0,0,0,16" ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="400">
                <Grid.ToolTip>
                    <ToolTip>
                        <TextBlock MaxWidth="420" TextWrapping="Wrap"
                                   Text="Optional. Paste a Discord channel webhook URL (Integrations → Webhooks). After SeeDrift Stop writes the night HTML, the file is POSTed as an attachment. The URL contains a secret token — do not share it. Leave empty to disable. Previous session report never uploads to Discord."/>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Discord webhook:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding DiscordWebhookUrl, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         FontFamily="Consolas"
                         ToolTip="https://discord.com/api/webhooks/… (secret — never share)"/>
            </Grid>

            <Grid Margin="0,0,0,10" ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="400">
                <Grid.ToolTip>
                    <ToolTip>
                        <TextBlock MaxWidth="420" TextWrapping="Wrap"
                                   Text="How many frames to plate-solve at once. Choices run from 1 up to 80% of physical cores (from GetLogicalProcessorInformation), rounded down (minimum 1). On a new install the default matches physical cores but never exceeds that ceiling. If that fails, core count falls back to logical processors (Environment.ProcessorCount). Each slot uses a separate solver instance; higher values use more RAM and CPU. Downsampling still comes only from your NINA Plate Solve profile."/>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Concurrency:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding PlateSolveParallelismOptions}"
                          SelectedItem="{Binding PlateSolveParallelism, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left"
                          MinWidth="44"
                          MaxWidth="68"
                          Foreground="#e2e8f0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#e2e8f0"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,16" ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="400">
                <Grid.ToolTip>
                    <ToolTip>
                        <TextBlock MaxWidth="420" TextWrapping="Wrap"
                                   Text="Night HTML lists only targets with at least this many solved frames in each run (1–500). Default 50."/>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Minimum exposures:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding MinExposuresPerTarget, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"
                         MinWidth="40"
                         MaxWidth="56"
                         MaxLength="3"/>
            </Grid>

            <Separator Margin="0,0,0,12"/>

            <TextBlock Text="Previous session Log" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Pick a saved NINA .log file from a prior session. SeeDrift plate-solves every LIGHT frame listed on “Saved image to …” lines in that file — fast, no date window. Same drift + sequencer correlation as Stop."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock Text="{Binding RecentLogSessionsStatusText, Mode=OneWay}"
                       Foreground="#94a3b8" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding RecentLogSessions}"
                          SelectedItem="{Binding SelectedRecentLogSession, Mode=TwoWay}"
                          DisplayMemberPath="DisplayLabel"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          MinWidth="320"
                          ToolTip="Recent NINA logs from the last 14 days. Selecting one fills the log path below."/>
                <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshRecentLogSessionsCommand}" Padding="10,4" MinWidth="88"/>
            </Grid>

            <TextBlock Text="Or browse/paste a NINA log path manually:"
                       Foreground="#64748b" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,5"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding TestReportLogFilePath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseTestReportLogCommand}" Padding="10,4" MinWidth="88"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Run previous session report" Command="{Binding RunTestReportCommand}" Padding="12,6"
                        IsEnabled="{Binding TestReportNotBusy, Mode=OneWay}"/>
            </StackPanel>

            <Border Margin="0,0,0,12" Padding="8,8,8,8" CornerRadius="4"
                    Background="#1e293b" BorderBrush="#334155" BorderThickness="1"
                    Visibility="{Binding TestReportChromeVisibility, Mode=OneWay}">
                <StackPanel>
                    <TextBlock Text="Previous session report status" FontWeight="SemiBold" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding TestReportStatusDisplayText, Mode=OneWay}" Foreground="#7dd3fc" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="{Binding NightReportLinkChromeVisibility, Mode=OneWay}">
                        <TextBlock Text="Open " Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="{Binding NightReportLinkFileName, Mode=OneWay}"
                                Command="{Binding OpenNightReportCommand}"
                                Padding="0" Margin="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#38bdf8" Cursor="Hand" FontSize="12"
                                VerticalAlignment="Center">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="{Binding NightReportLinkPathHint, Mode=OneWay}" MaxWidth="520" TextWrapping="Wrap"/>
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           TextDecorations="Underline"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <ProgressBar Height="16"
                                 Minimum="0"
                                 Background="#2D3748"
                                 Foreground="#38BDF8"
                                 BorderBrush="#4A5568"
                                 BorderThickness="1"
                                 Maximum="{Binding TestReportProgressMaximum, Mode=OneWay}"
                                 Value="{Binding TestReportProgressValue, Mode=OneWay}"
                                 IsIndeterminate="{Binding TestReportIndeterminate, Mode=OneWay}"/>
                </StackPanel>
            </Border>

            <Separator Margin="0,2,0,12"/>

            <TextBlock Text="Compare saved reports" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Pick two SeeDrift HTML reports created by this analytics build. Comparison uses the embedded report data, so it does not scan FITS files or run plate solving again."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock Text="{Binding SavedReportsStatusText, Mode=OneWay}"
                       Foreground="#94a3b8" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding SavedReports}"
                          SelectedItem="{Binding SelectedSavedReport, Mode=TwoWay}"
                          DisplayMemberPath="DisplayLabel"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          MinWidth="320"
                          ToolTip="Saved SeeDrift reports from AppData\Local\NINA\SeeDrift\Reports."/>
                <Button Grid.Column="1" Content="Before" Command="{Binding UseSavedReportAsBeforeCommand}" Padding="10,4" MinWidth="72" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Content="After" Command="{Binding UseSavedReportAsAfterCommand}" Padding="10,4" MinWidth="72" Margin="0,0,6,0"/>
                <Button Grid.Column="3"
                        Content="Delete selected"
                        Command="{Binding DeleteSelectedSavedReportCommand}"
                        Padding="10,4"
                        MinWidth="102"
                        Margin="0,0,6,0"
                        ToolTip="Removes only the report currently highlighted in the dropdown (one .html file per confirmation). Refresh rescans the folder and never deletes files."/>
                <Button Grid.Column="4" Content="Refresh" Command="{Binding RefreshSavedReportsCommand}" Padding="10,4" MinWidth="88"/>
            </Grid>

            <TextBlock Text="Or browse/paste report paths manually:"
                       Foreground="#64748b" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,5"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Before:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding CompareBeforeReportPath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseCompareBeforeReportCommand}" Padding="10,4" MinWidth="88"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="After:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding CompareAfterReportPath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseCompareAfterReportCommand}" Padding="10,4" MinWidth="88"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Compare saved reports" Command="{Binding RunCompareReportsCommand}" Padding="12,6"/>
            </StackPanel>

            <Border Margin="0,0,0,12" Padding="8,8,8,8" CornerRadius="4"
                    Background="#1e293b" BorderBrush="#334155" BorderThickness="1"
                    Visibility="{Binding CompareReportChromeVisibility, Mode=OneWay}">
                <StackPanel>
                    <TextBlock Text="Comparison status" FontWeight="SemiBold" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding CompareReportStatusText, Mode=OneWay}" Foreground="#7dd3fc" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding CompareReportLinkChromeVisibility, Mode=OneWay}">
                        <TextBlock Text="Open " Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="{Binding CompareReportLinkFileName, Mode=OneWay}"
                                Command="{Binding OpenCompareReportCommand}"
                                Padding="0" Margin="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#38bdf8" Cursor="Hand" FontSize="12"
                                VerticalAlignment="Center">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="{Binding CompareReportLinkPathHint, Mode=OneWay}" MaxWidth="520" TextWrapping="Wrap"/>
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           TextDecorations="Underline"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Tip: plate solving uses your NINA plate-solve profile (same solvers as the Plate Solve tool)." FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
