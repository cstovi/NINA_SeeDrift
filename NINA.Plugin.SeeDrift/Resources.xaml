<ResourceDictionary
    x:Class="NINA.Plugin.SeeDrift.Resources"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.Plugin.SeeDrift">

    <GeometryGroup x:Key="SeeDrift_Icon" FillRule="Nonzero">
        <PathGeometry Figures="M6,18 L6,8 L18,8"/>
        <PathGeometry Figures="M8,15 L11,12 L14,13 L17,9"/>
    </GeometryGroup>

    <DataTemplate x:Key="SeeDrift_Options" DataType="{x:Type local:SeeDriftPlugin}">
        <StackPanel Margin="8" MaxWidth="620">

            <TextBlock TextWrapping="Wrap" Foreground="#cbd5e1" FontSize="12" Margin="0,0,0,14"
                       Text="Sequence tip: add SeeDrift Start at the top of your night's sequence and SeeDrift Stop at the bottom. When Stop runs, SeeDrift reads logs, plate-solves saved LIGHT frames from that window, and appends the drift HTML report. Many exposures mean many solves: increase Concurrency if your PC can handle more parallel solving, or reduce it if CPU/RAM pressure is too high."/>

            <Grid Margin="0,0,0,16" ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="400">
                <Grid.ToolTip>
                    <ToolTip>
                        <TextBlock MaxWidth="420" TextWrapping="Wrap"
                                   Text="Optional. Paste a Discord channel webhook URL (Integrations → Webhooks). After SeeDrift Stop writes the night HTML, the file is POSTed as an attachment. The URL contains a secret token — do not share it. Leave empty to disable. Run report on this page never uploads to Discord."/>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Discord webhook:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding DiscordWebhookUrl, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         FontFamily="Consolas"
                         ToolTip="https://discord.com/api/webhooks/… (secret — never share)"/>
            </Grid>

            <Grid Margin="0,0,0,10" ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="400">
                <Grid.ToolTip>
                    <ToolTip>
                        <TextBlock MaxWidth="420" TextWrapping="Wrap"
                                   Text="How many frames to plate-solve at once. Choices run from 1 up to 80% of physical cores (from GetLogicalProcessorInformation), rounded down (minimum 1). On a new install the default matches physical cores but never exceeds that ceiling. If that fails, core count falls back to logical processors (Environment.ProcessorCount). Each slot uses a separate solver instance; higher values use more RAM and CPU. Downsampling still comes only from your NINA Plate Solve profile."/>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Concurrency:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding PlateSolveParallelismOptions}"
                          SelectedItem="{Binding PlateSolveParallelism, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left"
                          MinWidth="44"
                          MaxWidth="68"
                          Foreground="#e2e8f0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#e2e8f0"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,16" ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="400">
                <Grid.ToolTip>
                    <ToolTip>
                        <TextBlock MaxWidth="420" TextWrapping="Wrap"
                                   Text="Night HTML lists only targets with at least this many solved frames in each run (1–500). Default 50."/>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Minimum exposures:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding MinExposuresPerTarget, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"
                         MinWidth="40"
                         MaxWidth="56"
                         MaxLength="3"/>
            </Grid>

            <TextBlock Text="Alternative image location mapping" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="When FITS were moved after capture, map the log path prefix to a secondary folder."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,12" ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="400">
                <Grid.ToolTip>
                    <ToolTip>
                        <TextBlock MaxWidth="420" TextWrapping="Wrap"
                                   Text="Secondary location for FITS files. SeeDrift always plate-solves using the full path from the NINA log (“Saved image to …”) when that file still exists on disk.&#x0a;&#x0a;If the file is missing—for example you moved the session to another drive after capture—SeeDrift can look under a second root: when the log path starts with Original image root, the same subfolders and filename are tried under Alternative image root.&#x0a;&#x0a;Example: logs point to C:\Users\…\N.I.N.A\M42\lights\2026-05-15\img.fits but files now live under P:\Astro\Home\…. Set original root to C:\Users\…\N.I.N.A and alternative root to P:\Astro\Home. Leave both empty to disable.&#x0a;&#x0a;Original root should match what your logs show, not necessarily today’s NINA Options → Imaging image path (that may have changed since the session)."/>
                    </ToolTip>
                </Grid.ToolTip>
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Original image root:" VerticalAlignment="Center" Margin="0,0,8,0"
                                   ToolTip="Prefix from the log paths NINA wrote when frames were saved."/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding AlternativeImageMappingOriginalRoot, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="Consolas"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Browse" Command="{Binding BrowseAlternativeMappingOriginalRootCommand}" Padding="8,4" Margin="0,0,6,0"/>
                            <Button Content="Clear" Command="{Binding ClearAlternativeMappingOriginalRootCommand}" Padding="8,4" Margin="0,0,6,0"/>
                            <Button Content="Use NINA path" Command="{Binding UseNinaImagePathForMappingOriginalRootCommand}" Padding="8,4"
                                    ToolTip="Convenience only—confirm it matches the paths in your log file."/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Alternative image root:" VerticalAlignment="Center" Margin="0,0,8,0"
                                   ToolTip="Secondary folder where the same relative tree was moved; used only when the logged path is missing."/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding AlternativeImageMappingAlternativeRoot, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="Consolas"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Browse" Command="{Binding BrowseAlternativeMappingAlternativeRootCommand}" Padding="8,4" Margin="0,0,6,0"/>
                            <Button Content="Clear" Command="{Binding ClearAlternativeMappingAlternativeRootCommand}" Padding="8,4"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>

            <Separator Margin="0,0,0,12"/>

            <TextBlock Text="Create report" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Choose a NINA session log, then run a drift report on every LIGHT frame it recorded (full log file — no Start/Stop window)."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock Text="{Binding RecentLogSessionsStatusText, Mode=OneWay}"
                       Foreground="#94a3b8" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding RecentLogSessions}"
                          SelectedItem="{Binding SelectedRecentLogSession, Mode=TwoWay}"
                          DisplayMemberPath="DisplayLabel"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          MinWidth="320"
                          ToolTip="Recent NINA logs — the dropdown shows the last ten sessions. Selecting one fills the log path below. Unknown scope means SeeDrift did not find Alpaca telescope discovery, Telephoto Camera connect, or Telephoto disconnect (Disconnecting from … Seestar … Telephoto Camera) in that log — it does not affect solving."/>
                <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshRecentLogSessionsCommand}" Padding="10,4" MinWidth="88"/>
            </Grid>

            <Border Margin="0,0,0,10" Padding="8,6" CornerRadius="4"
                    Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    Visibility="{Binding SelectedRecentLogSessionDetailVisibility, Mode=OneWay}">
                <TextBlock Text="{Binding SelectedRecentLogSessionDetailText, Mode=OneWay}"
                           Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
            </Border>

            <TextBlock Text="Log file path" FontWeight="SemiBold" Foreground="#e2e8f0" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding TestReportLogFilePath, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         ToolTip="Type or paste any NINA .log path here. This overrides the dropdown above when you click Run report."/>
                <Button Grid.Column="1"
                        Content="Browse…"
                        Command="{Binding BrowseTestReportLogCommand}"
                        Padding="10,4"
                        MinWidth="88"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Run report" Command="{Binding RunTestReportCommand}" Padding="12,6"
                        IsEnabled="{Binding TestReportNotBusy, Mode=OneWay}"/>
            </StackPanel>

            <Border Margin="0,0,0,12" Padding="8,8,8,8" CornerRadius="4"
                    Background="#1e293b" BorderBrush="#334155" BorderThickness="1"
                    Visibility="{Binding TestReportChromeVisibility, Mode=OneWay}">
                <StackPanel>
                    <TextBlock Text="Report status" FontWeight="SemiBold" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding TestReportStatusDisplayText, Mode=OneWay}" Foreground="#7dd3fc" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedLogSavedReportSummaryText, Mode=OneWay}"
                               Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"
                               Visibility="{Binding SelectedLogSavedReportSummaryVisibility, Mode=OneWay}"/>
                    <TextBlock Text="{Binding SelectedLogNoReportHintText, Mode=OneWay}"
                               Foreground="#fbbf24" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"
                               Visibility="{Binding SelectedLogNoReportHintVisibility, Mode=OneWay}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="{Binding NightReportLinkChromeVisibility, Mode=OneWay}">
                        <TextBlock Text="Open " Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="{Binding NightReportLinkFileName, Mode=OneWay}"
                                Command="{Binding OpenNightReportCommand}"
                                Padding="0" Margin="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#38bdf8" Cursor="Hand" FontSize="12"
                                VerticalAlignment="Center">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="{Binding NightReportLinkPathHint, Mode=OneWay}" MaxWidth="520" TextWrapping="Wrap"/>
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           TextDecorations="Underline"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <ProgressBar Height="16"
                                 Minimum="0"
                                 Background="#2D3748"
                                 Foreground="#38BDF8"
                                 BorderBrush="#4A5568"
                                 BorderThickness="1"
                                 Maximum="{Binding TestReportProgressMaximum, Mode=OneWay}"
                                 Value="{Binding TestReportProgressValue, Mode=OneWay}"
                                 IsIndeterminate="{Binding TestReportIndeterminate, Mode=OneWay}"/>
                </StackPanel>
            </Border>

            <Separator Margin="0,2,0,12"/>

            <TextBlock Text="Compare saved reports" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Pick Before and After reports from the library. Comparison uses embedded report data — no FITS scan or plate solving."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock Text="{Binding SavedReportsStatusText, Mode=OneWay}"
                       Foreground="#94a3b8" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Refresh library" Command="{Binding RefreshSavedReportsCommand}" Padding="10,4" MinWidth="108" Margin="0,0,8,0"/>
                <Button Content="Delete report…"
                        Command="{Binding DeleteSelectedSavedReportCommand}"
                        Padding="10,4"
                        MinWidth="108"
                        ToolTip="Deletes the After report if selected, otherwise the Before report (one .html file per confirmation)."/>
            </StackPanel>

            <TextBlock Text="Before" FontWeight="SemiBold" Foreground="#e2e8f0" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding SavedReports}"
                      SelectedItem="{Binding CompareBeforeReport, Mode=TwoWay}"
                      DisplayMemberPath="DisplayLabel"
                      VerticalAlignment="Center"
                      Margin="0,0,0,6"
                      MinWidth="320"
                      ToolTip="Earlier session (baseline) for comparison."/>
            <Border Margin="0,0,0,12" Padding="8,6" CornerRadius="4"
                    Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    Visibility="{Binding CompareBeforeReportDetailVisibility, Mode=OneWay}">
                <TextBlock Text="{Binding CompareBeforeReportDetailText, Mode=OneWay}"
                           Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
            </Border>

            <TextBlock Text="After" FontWeight="SemiBold" Foreground="#e2e8f0" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding SavedReports}"
                      SelectedItem="{Binding CompareAfterReport, Mode=TwoWay}"
                      DisplayMemberPath="DisplayLabel"
                      VerticalAlignment="Center"
                      Margin="0,0,0,6"
                      MinWidth="320"
                      ToolTip="Later session to compare against Before."/>
            <Border Margin="0,0,0,12" Padding="8,6" CornerRadius="4"
                    Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    Visibility="{Binding CompareAfterReportDetailVisibility, Mode=OneWay}">
                <TextBlock Text="{Binding CompareAfterReportDetailText, Mode=OneWay}"
                           Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Compare saved reports" Command="{Binding RunCompareReportsCommand}" Padding="12,6"/>
            </StackPanel>

            <Border Margin="0,0,0,12" Padding="8,8,8,8" CornerRadius="4"
                    Background="#1e293b" BorderBrush="#334155" BorderThickness="1"
                    Visibility="{Binding CompareReportChromeVisibility, Mode=OneWay}">
                <StackPanel>
                    <TextBlock Text="Comparison status" FontWeight="SemiBold" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding CompareReportStatusText, Mode=OneWay}" Foreground="#7dd3fc" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding CompareReportLinkChromeVisibility, Mode=OneWay}">
                        <TextBlock Text="Open " Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="{Binding CompareReportLinkFileName, Mode=OneWay}"
                                Command="{Binding OpenCompareReportCommand}"
                                Padding="0" Margin="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#38bdf8" Cursor="Hand" FontSize="12"
                                VerticalAlignment="Center">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="{Binding CompareReportLinkPathHint, Mode=OneWay}" MaxWidth="520" TextWrapping="Wrap"/>
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           TextDecorations="Underline"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Tip: plate solving uses your NINA plate-solve profile (same solvers as the Plate Solve tool)." FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
