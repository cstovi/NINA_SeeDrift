<ResourceDictionary
    x:Class="NINA.Plugin.SeeDrift.Resources"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.Plugin.SeeDrift"
    xmlns:vm="clr-namespace:NINA.Plugin.SeeDrift.ViewModels"
    xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf">

    <GeometryGroup x:Key="SeeDrift_Icon" FillRule="Nonzero">
        <PathGeometry Figures="M3,12 L21,12 M12,3 L12,21 M6,6 L18,18 M18,6 L6,18"/>
    </GeometryGroup>

    <DataTemplate x:Key="NINA.Plugin.SeeDrift.ViewModels.DriftPlotDockableVM_Dockable" DataType="{x:Type vm:DriftPlotDockableVM}">
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Reset trace" Command="{Binding ResetCommand}" Margin="0,0,8,0" Padding="8,4"/>
                    <Button Content="Import FITS folder…" Command="{Binding ImportFolderCommand}" Margin="0,0,8,0" Padding="8,4"/>
                    <Button Content="Export HTML…" Command="{Binding ExportHtmlCommand}" Padding="8,4"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding SampleCount, StringFormat=Frames: {0}}"
                           VerticalAlignment="Center" Foreground="#AAA" Margin="12,0,0,0"/>
            </DockPanel>
            <TextBlock Grid.Row="1" Text="{Binding LastSummary}" TextWrapping="Wrap" Foreground="#CCC" Margin="0,0,0,8"/>
            <oxy:PlotView Grid.Row="2" Model="{Binding PlotModel}" MinHeight="240"/>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SeeDrift_Options" DataType="{x:Type local:SeeDriftPlugin}">
        <StackPanel Margin="8" MaxWidth="560">
            <TextBlock Text="Tracking" FontWeight="Bold" Margin="0,0,0,6"/>
            <CheckBox Content="Only record Seestar cameras (camera name or INSTRUME contains Seestar)"
                      IsChecked="{Binding OnlySeestarCameras}" Margin="0,0,0,8"/>
            <CheckBox Content="Reset trace when FITS OBJECT name changes"
                      IsChecked="{Binding AutoResetOnTargetChange}" Margin="0,0,0,12"/>

            <TextBlock Text="HTML export" FontWeight="Bold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Default folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding HtmlExportFolder, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            </Grid>

            <TextBlock TextWrapping="Wrap" Foreground="#888" FontSize="11">
                Offsets are arcseconds relative to the first accepted LIGHT in the current trace (after Reset).
                Dither appears as steps in RA and/or Dec — compare spike directions and sizes to your dither settings.
            </TextBlock>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
