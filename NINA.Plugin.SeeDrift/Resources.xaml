<ResourceDictionary
    x:Class="NINA.Plugin.SeeDrift.Resources"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.Plugin.SeeDrift">

    <GeometryGroup x:Key="SeeDrift_Icon" FillRule="Nonzero">
        <PathGeometry Figures="M3,12 L21,12 M12,3 L12,21 M6,6 L18,18 M18,6 L6,18"/>
    </GeometryGroup>

    <DataTemplate x:Key="SeeDrift_Options" DataType="{x:Type local:SeeDriftPlugin}">
        <StackPanel Margin="8" MaxWidth="620">

            <TextBlock Text="Drift report (plate solving)" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="SeeDrift Stop plate-solves LIGHT frames saved under your NINA image folder whose observation time falls between SeeDrift Start and Stop (UTC window). Configure NINA Options → Imaging → image file path."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>

            <TextBlock Text="NINA image folder (read-only)" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding NINAImageDirectoryDisplay}" TextWrapping="Wrap" Foreground="#CCC" Margin="0,0,0,16"/>

            <TextBlock Text="HTML export" FontWeight="Bold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Night report folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding HtmlExportFolder, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            </Grid>

            <TextBlock Text="Scratch / temp (reserved)" FontWeight="Bold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Working folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding TempWorkingFolder, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            </Grid>

            <Separator Margin="0,0,0,12"/>

            <TextBlock Text="Test report" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Uses the same pipeline as SeeDrift Stop: scans the NINA image folder recursively and filters by observation UTC. Pick calendar date and time in UTC (not your PC’s local zone)."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock Text="Observation start (UTC)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <DatePicker SelectedDate="{Binding TestObservationStartDateUtc}" Width="150" VerticalAlignment="Center"/>
                <TextBlock Text="time" Margin="12,0,6,0" VerticalAlignment="Center" Foreground="#AAA" FontSize="11"/>
                <ComboBox ItemsSource="{Binding UtcHours}" SelectedItem="{Binding TestObservationStartHourUtc}" Width="56" VerticalAlignment="Center" Margin="0,0,4,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat={}{0:D2}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding UtcMinutes}" SelectedItem="{Binding TestObservationStartMinuteUtc}" Width="56" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat={}{0:D2}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <TextBlock Text="Observation end (UTC)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <DatePicker SelectedDate="{Binding TestObservationEndDateUtc}" Width="150" VerticalAlignment="Center"/>
                <TextBlock Text="time" Margin="12,0,6,0" VerticalAlignment="Center" Foreground="#AAA" FontSize="11"/>
                <ComboBox ItemsSource="{Binding UtcHours}" SelectedItem="{Binding TestObservationEndHourUtc}" Width="56" VerticalAlignment="Center" Margin="0,0,4,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat={}{0:D2}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding UtcMinutes}" SelectedItem="{Binding TestObservationEndMinuteUtc}" Width="56" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat={}{0:D2}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Run test report" Command="{Binding RunTestReportCommand}" Padding="12,6" Margin="0,0,12,0"/>
                <Button Content="Clear completed targets (session)" Command="{Binding ResetSessionCommand}" Padding="12,6"/>
            </StackPanel>

            <TextBlock Text="Tip: plate solving uses your NINA plate-solve profile (same solvers as the Plate Solve tool)." FontSize="11" Foreground="#888" TextWrapping="Wrap"/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
