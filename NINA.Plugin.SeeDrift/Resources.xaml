<ResourceDictionary
    x:Class="NINA.Plugin.SeeDrift.Resources"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.Plugin.SeeDrift">

    <GeometryGroup x:Key="SeeDrift_Icon" FillRule="Nonzero">
        <PathGeometry Figures="M3,12 L21,12 M12,3 L12,21 M6,6 L18,18 M18,6 L6,18"/>
    </GeometryGroup>

    <DataTemplate x:Key="SeeDrift_Options" DataType="{x:Type local:SeeDriftPlugin}">
        <StackPanel Margin="8" MaxWidth="620">

            <TextBlock Text="HTML export" FontWeight="Bold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Night report folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Column="1">
                    <TextBox Text="{Binding HtmlExportFolder, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <TextBlock Text="Leave empty for Documents\SeeDrift (not Desktop). After Stop/Test, NINA’s status bar shows the full saved path."
                               FontSize="10" Foreground="#777" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Scratch / temp (reserved)" FontWeight="Bold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Working folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding TempWorkingFolder, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Concurrency:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Column="1">
                    <TextBox Text="{Binding PlateSolveParallelism, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <TextBlock Text="How many frames to plate-solve at once (1–16). Default 4. Each slot uses a separate solver instance; higher values use more RAM and CPU. Downsampling still comes only from your NINA Plate Solve profile."
                               FontSize="10" Foreground="#777" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Minimum exposures:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Column="1">
                    <TextBox Text="{Binding MinExposuresPerTarget, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <TextBlock Text="Night HTML lists only targets with at least this many solved frames in each batch (1–500). Default 1 includes every target."
                               FontSize="10" Foreground="#777" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <Separator Margin="0,0,0,12"/>

            <TextBlock Text="Test report (historic session)" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Pick a saved NINA .log file. SeeDrift plate-solves every LIGHT frame listed on “Saved image to …” lines in that file — fast, no date window. Same drift + sequencer correlation as Stop."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock Text="NINA log file" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding TestReportLogFilePath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseTestReportLogCommand}" Padding="10,4" MinWidth="88"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Run test report" Command="{Binding RunTestReportCommand}" Padding="12,6" Margin="0,0,12,0"
                        IsEnabled="{Binding TestReportNotBusy, Mode=OneWay}"/>
                <Button Content="Clear completed targets (session)" Command="{Binding ResetSessionCommand}" Padding="12,6"/>
            </StackPanel>

            <Border Margin="0,0,0,12" Padding="8,8,8,8" CornerRadius="4"
                    Background="#1e293b" BorderBrush="#334155" BorderThickness="1"
                    Visibility="{Binding TestReportChromeVisibility, Mode=OneWay}">
                <StackPanel>
                    <TextBlock Text="Test report status" FontWeight="SemiBold" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding TestReportStatusText, Mode=OneWay}" Foreground="#7dd3fc" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <ProgressBar Height="16"
                                 Minimum="0"
                                 Background="#2D3748"
                                 Foreground="#38BDF8"
                                 BorderBrush="#4A5568"
                                 BorderThickness="1"
                                 Maximum="{Binding TestReportProgressMaximum, Mode=OneWay}"
                                 Value="{Binding TestReportProgressValue, Mode=OneWay}"
                                 IsIndeterminate="{Binding TestReportIndeterminate, Mode=OneWay}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="While Test report runs, status updates under Run; when finished, the last line stays until you run again. SeeDrift Stop uses NINA’s main status bar instead."
                       FontSize="10" Foreground="#777" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <TextBlock Text="Tip: plate solving uses your NINA plate-solve profile (same solvers as the Plate Solve tool)." FontSize="11" Foreground="#888" TextWrapping="Wrap"/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
